---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EmailCaptureInline from "../../components/EmailCaptureInline.astro";
import AuthorBio from "../../components/AuthorBio.astro";
import { organization, webPage, buildGraph } from "../../lib/schema";

const site = "https://siftedtools.com";
const url = `${site}/es/`;
const updated = "2026-06-30";

const schema = [
  buildGraph(
    organization(),
    webPage({
      url,
      title: "Herramientas IA para e-commerce: el veredicto, no la lista",
      description:
        "Comparador independiente de las mejores herramientas IA para tiendas Shopify, WooCommerce y DTC. Probadas en tiendas reales, clasificadas por mérito.",
      updatedAt: new Date(updated),
      lang: "es",
    })
  ),
];
---
<BaseLayout
  title="Herramientas IA para e-commerce: el veredicto, no la lista | SiftedTools"
  description="Comparador independiente de las mejores herramientas IA para tiendas Shopify, WooCommerce y DTC. Probadas en tiendas reales, clasificadas por mérito."
  canonical={url}
  alternates={[
    { lang: "es", href: `${site}/es/` },
    { lang: "fr", href: `${site}/fr/` },
    { lang: "en", href: `${site}/en/` },
    { lang: "de", href: `${site}/de/` },
  ]}
  updatedAt={updated}
  schema={schema}
>
  <div class="home">
    <section class="hero">
      <p class="kicker ui">Comparador independiente de herramientas IA para e-commerce</p>
      <h1>La herramienta correcta.<br /><em>No la lista m&aacute;s larga.</em></h1>
      <p class="subtitle">Probamos las herramientas IA en tiendas reales, no desde una p&aacute;gina de producto. Veredicto claro, metodolog&iacute;a documentada, cero sesgo.</p>
    </section>

    <section class="coming">
      <h2 class="ui">Comparativas en preparaci&oacute;n</h2>
      <p>Nuestras comparativas en espa&ntilde;ol est&aacute;n en camino. Mientras tanto, suscr&iacute;bete para recibir el Bar&oacute;metro GEO en cuanto se publique.</p>
      <EmailCaptureInline />
    </section>

    <div class="author-slot"><AuthorBio updatedAt={updated} /></div>
  </div>
</BaseLayout>

<style>
  .home{max-width:760px;margin:0 auto;padding:48px 24px}
  .hero{text-align:center;margin-bottom:56px}
  .kicker{font-size:13px;letter-spacing:0.08em;text-transform:uppercase;color:var(--gold);margin-bottom:20px}
  .hero h1{font-size:clamp(36px,6vw,56px);line-height:1.05;letter-spacing:-0.02em}
  .hero em{font-style:italic;color:var(--gold)}
  .subtitle{font-size:clamp(17px,2.5vw,20px);color:var(--slate);max-width:52ch;margin:20px auto 0;line-height:1.5}
  .coming{margin:48px 0}
  .coming h2{font-size:clamp(22px,3vw,28px);margin-bottom:8px}
  .coming p{color:var(--slate);margin-bottom:24px;max-width:60ch}
  .author-slot{margin:48px 0}
</style>
