---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import EmailCaptureInline from "../../components/EmailCaptureInline.astro";
import { organization, webPage, buildGraph } from "../../lib/schema";

const SITE = "https://siftedtools.com";
const LANG = "en";
const url = `${SITE}/${LANG}/comparisons/`;
const updated = "2026-06-30";

const all = await getCollection("tools", ({ data }) => data.draft !== true && data.lang === LANG);
const comparisons = all.sort((a, b) => new Date(b.data.updatedAt).getTime() - new Date(a.data.updatedAt).getTime());
const slugOf = (entry) => entry.id.replace(/\.(md|mdx)$/i, "").replace(new RegExp(`^${LANG}/`), "");

const allGuides = await getCollection("guides", ({ data }) => data.draft !== true && data.lang === LANG);
const guides = allGuides.sort((a, b) => new Date(b.data.updatedAt).getTime() - new Date(a.data.updatedAt).getTime());

const schema = [
  buildGraph(
    organization(),
    webPage({
      url,
      title: "All AI tool comparisons for e-commerce",
      description: "All our AI tool comparisons tested on real e-commerce stores: customer service, product descriptions, photos, email, SEO, ad creatives.",
      updatedAt: new Date(updated),
      lang: LANG,
    })
  ),
];
---
<BaseLayout
  title="All AI Tool Comparisons for E-commerce | SiftedTools"
  description="All our AI tool comparisons tested on real e-commerce stores: customer service, product descriptions, photos, email, SEO, ad creatives."
  canonical={url}
  alternates={[
    { lang: "en", href: url },
    { lang: "fr", href: `${SITE}/fr/comparatifs/` },
    { lang: "es", href: `${SITE}/es/comparativas/` },
    { lang: "de", href: `${SITE}/de/vergleiche/` },
  ]}
  updatedAt={updated}
  schema={schema}
>
  <main class="hub">
    <div class="wrap">

      <header class="hub-head">
        <p class="eyebrow">The sieve · {comparisons.length} comparisons published</p>
        <h1>All our AI tool comparisons for e-commerce</h1>
        <p class="lede">Every comparison is based on real-store testing. No ranking reflects a marketing budget. See our <a href={`/${LANG}/methodology/`}>methodology</a>.</p>
      </header>

      {comparisons.length === 0 ? (
        <p class="empty">No comparisons published yet. Our English comparisons are being prepared. Check back soon.</p>
      ) : (
        <div class="grid">
          {comparisons.map((entry) => {
            const slug = slugOf(entry);
            const href = `/${LANG}/${slug}/`;
            const dateStr = new Date(entry.data.updatedAt).toLocaleDateString("en-GB", { month: "long", year: "numeric" });
            return (
              <a class="card" href={href}>
                <span class="card-eyebrow">Comparison · {dateStr}</span>
                <h2>{entry.data.title}</h2>
                <p>{entry.data.description}</p>
                <span class="card-arrow">Read the verdict →</span>
              </a>
            );
          })}
        </div>
      )}

      {guides.length > 0 && (
        <section id="guides" class="guides-section">
          <header class="hub-head">
            <p class="eyebrow">Practical guides · {guides.length} guides</p>
            <h2 class="section-title">Our guides to take action</h2>
            <p class="lede">Beyond comparisons, our guides explain how to use AI concretely in your store.</p>
          </header>
          <div class="grid">
            {guides.map((entry) => {
              const slug = slugOf(entry);
              const href = `/${LANG}/${slug}/`;
              return (
                <a class="card" href={href}>
                  <span class="card-eyebrow">Guide</span>
                  <h2>{entry.data.title}</h2>
                  <p>{entry.data.description}</p>
                  <span class="card-arrow">Read the guide →</span>
                </a>
              );
            })}
          </div>
        </section>
      )}

      <div class="newsletter-slot"><EmailCaptureInline /></div>

    </div>
  </main>
</BaseLayout>

<style>
  .hub { padding: 60px 0 80px; background: var(--porcelain, #F4F5F2); min-height: calc(100vh - 200px); }
  .wrap { max-width: 980px; margin: 0 auto; padding: 0 24px; }
  .hub-head { margin-bottom: 48px; }
  .eyebrow { font-family: 'Space Mono', monospace; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold, #B17C2E); margin-bottom: 1rem; }
  h1 { font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: clamp(2rem, 5vw, 2.75rem); line-height: 1.15; letter-spacing: -0.02em; color: var(--ink, #16171D); margin-bottom: 1rem; }
  .lede { font-size: 1.1rem; color: var(--slate, #6B6C73); line-height: 1.6; max-width: 60ch; }
  .lede a { color: var(--ink, #16171D); text-decoration: underline; text-decoration-color: var(--gold, #B17C2E); text-underline-offset: 3px; }
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .card { background: white; border: 1px solid var(--mesh, #C9CAC4); border-radius: 4px; padding: 28px 26px; text-decoration: none; color: var(--ink, #16171D); transition: border-color 0.15s, transform 0.15s; position: relative; }
  .card::before { content: ''; position: absolute; top: -1px; left: 28px; right: 28px; height: 2px; background: var(--gold, #B17C2E); opacity: 0; transition: opacity 0.15s; }
  .card:hover { border-color: var(--gold, #B17C2E); transform: translateY(-2px); }
  .card:hover::before { opacity: 1; }
  .card-eyebrow { font-family: 'Space Mono', monospace; font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold, #B17C2E); display: block; margin-bottom: 0.75rem; }
  .card h2 { font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: 1.25rem; line-height: 1.3; margin-bottom: 0.75rem; color: var(--ink, #16171D); }
  .card p { font-family: 'Space Grotesk', sans-serif; font-size: 0.95rem; color: var(--slate, #6B6C73); line-height: 1.5; margin-bottom: 1.25rem; }
  .card-arrow { font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem; font-weight: 600; color: var(--gold, #B17C2E); }
  .empty { font-family: 'Space Grotesk', sans-serif; color: var(--slate, #6B6C73); text-align: center; padding: 60px 0; background: white; border-radius: 4px; }
  .guides-section { margin-top: 64px; scroll-margin-top: 80px; }
  .section-title { font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: clamp(1.6rem, 4vw, 2rem); line-height: 1.2; letter-spacing: -0.02em; color: var(--ink, #16171D); margin-bottom: 1rem; }
  .newsletter-slot { margin-top: 56px; }
  @media (max-width: 720px) { .grid { grid-template-columns: 1fr; } }
</style>
