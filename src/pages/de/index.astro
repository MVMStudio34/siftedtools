---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EmailCaptureInline from "../../components/EmailCaptureInline.astro";
import AuthorBio from "../../components/AuthorBio.astro";
import { organization, webPage, buildGraph } from "../../lib/schema";

const site = "https://siftedtools.com";
const url = `${site}/de/`;
const updated = "2026-06-30";

const schema = [
  buildGraph(
    organization(),
    webPage({
      url,
      title: "KI-Tools für E-Commerce: Das Urteil, nicht die Liste",
      description:
        "Unabhängiger Vergleich der besten KI-Tools für Shopify-, WooCommerce- und DTC-Shops. An echten Shops getestet, nach Leistung bewertet.",
      updatedAt: new Date(updated),
      lang: "de",
    })
  ),
];
---
<BaseLayout
  title="KI-Tools für E-Commerce: Das Urteil, nicht die Liste | SiftedTools"
  description="Unabhängiger Vergleich der besten KI-Tools für Shopify-, WooCommerce- und DTC-Shops. An echten Shops getestet, nach Leistung bewertet."
  canonical={url}
  alternates={[
    { lang: "de", href: `${site}/de/` },
    { lang: "fr", href: `${site}/fr/` },
    { lang: "en", href: `${site}/en/` },
    { lang: "es", href: `${site}/es/` },
  ]}
  updatedAt={updated}
  schema={schema}
>
  <div class="home">
    <section class="hero">
      <p class="kicker ui">Unabh&auml;ngiger KI-Tools-Vergleich f&uuml;r E-Commerce</p>
      <h1>Das richtige Tool.<br /><em>Nicht die l&auml;ngste Liste.</em></h1>
      <p class="subtitle">Wir testen KI-Tools an echten Shops, nicht von Produktseiten aus. Klares Urteil, dokumentierte Methodik, keine Verzerrung.</p>
    </section>

    <section class="coming">
      <h2 class="ui">Vergleiche in Vorbereitung</h2>
      <p>Unsere deutschen Vergleiche werden gerade erstellt. Abonnieren Sie in der Zwischenzeit das GEO-Barometer, um es direkt bei Ver&ouml;ffentlichung zu erhalten.</p>
      <EmailCaptureInline />
    </section>

    <div class="author-slot"><AuthorBio updatedAt={updated} /></div>
  </div>
</BaseLayout>

<style>
  .home{max-width:760px;margin:0 auto;padding:48px 24px}
  .hero{text-align:center;margin-bottom:56px}
  .kicker{font-size:13px;letter-spacing:0.08em;text-transform:uppercase;color:var(--gold);margin-bottom:20px}
  .hero h1{font-size:clamp(36px,6vw,56px);line-height:1.05;letter-spacing:-0.02em}
  .hero em{font-style:italic;color:var(--gold)}
  .subtitle{font-size:clamp(17px,2.5vw,20px);color:var(--slate);max-width:52ch;margin:20px auto 0;line-height:1.5}
  .coming{margin:48px 0}
  .coming h2{font-size:clamp(22px,3vw,28px);margin-bottom:8px}
  .coming p{color:var(--slate);margin-bottom:24px;max-width:60ch}
  .author-slot{margin:48px 0}
</style>
