---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EmailCaptureInline from "../../components/EmailCaptureInline.astro";
import { organization, webPage, buildGraph } from "../../lib/schema";

const SITE = "https://siftedtools.com";
const url = `${SITE}/fr/outils-ia-ecommerce/`;
const updated = "2026-06-22";

const categories = [
  {
    title: "Service client IA",
    description: "Chatbots et helpdesk pour automatiser le SAV de votre boutique.",
    winner: "Gorgias",
    href: "/fr/outils-ia-service-client/",
    available: true,
  },
  {
    title: "Fiches produits IA",
    description: "Rédaction à grande échelle pour catalogues multi-SKU et multilingues.",
    winner: "Jasper",
    href: "/fr/outils-ia-fiches-produits/",
    available: true,
  },
  {
    title: "Photos produits IA",
    description: "Retouche, packshots et arrière-plans sans studio ni photographe.",
    winner: "PhotoRoom",
    href: "/fr/outils-ia-photos-produits/",
    available: true,
  },
  {
    title: "Email marketing IA",
    description: "Séquences, segmentation et personnalisation pilotées par IA.",
    winner: "Klaviyo",
    href: "/fr/outils-ia-email-marketing/",
    available: true,
  },
  {
    title: "SEO et contenu IA",
    description: "Articles, pages catégories et stratégie de contenu optimisée.",
    winner: "Surfer SEO",
    href: "/fr/outils-ia-seo-ecommerce/",
    available: true,
  },
  {
    title: "Créas publicitaires IA",
    description: "Visuels d'ads Meta et Google générés en quelques secondes.",
    winner: "AdCreative.ai",
    href: "/fr/outils-ia-creas-publicitaires/",
    available: true,
  },
];

const schema = [
  buildGraph(
    organization(),
    webPage({
      url,
      title: "Outils IA pour l'e-commerce : tous les cas d'usage",
      description: "Catalogue des outils IA testés par SiftedTools pour les boutiques e-commerce : service client, fiches produits, photos, email, SEO, créas publicitaires.",
      updatedAt: new Date(updated),
      lang: "fr",
    })
  ),
];
---
<BaseLayout
  title="Outils IA pour l'e-commerce : tous les cas d'usage | SiftedTools"
  description="Catalogue des outils IA testés par SiftedTools pour les boutiques e-commerce : service client, fiches produits, photos, email, SEO, créas publicitaires."
  canonical={url}
  alternates={[{ lang: "fr", href: url }]}
  updatedAt={updated}
  schema={schema}
>
  <main class="hub">
    <div class="wrap">

      <header class="hub-head">
        <p class="eyebrow">Catalogue · Par cas d'usage</p>
        <h1>Outils IA pour l'e-commerce</h1>
        <p class="lede">Tous les outils que nous testons, classés par besoin opérationnel. Cliquez sur une catégorie pour voir notre verdict détaillé. Lecture rapide ? Voir notre <a href="/fr/meilleurs-outils-ia-ecommerce/">guide pilier 2026</a>.</p>
      </header>

      <div class="grid">
        {categories.map((cat) => (
          <a class={`card ${cat.available ? '' : 'card-coming'}`} href={cat.available ? cat.href : '#'}>
            <span class="card-eyebrow">{cat.available ? `Verdict · ${cat.winner}` : 'Bientôt disponible'}</span>
            <h2>{cat.title}</h2>
            <p>{cat.description}</p>
            <span class="card-arrow">{cat.available ? 'Voir le comparatif →' : `En préparation`}</span>
          </a>
        ))}
      </div>

      <div class="hint">
        <p><strong>Les comparatifs marqués "En préparation"</strong> sont sur notre roadmap. Pour être notifié à leur publication, inscrivez-vous au Baromètre GEO mensuel ci-dessous.</p>
      </div>

      <div class="newsletter-slot"><EmailCaptureInline /></div>

    </div>
  </main>
</BaseLayout>

<style>
  .hub { padding: 60px 0 80px; background: var(--porcelain, #F4F5F2); min-height: calc(100vh - 200px); }
  .wrap { max-width: 980px; margin: 0 auto; padding: 0 24px; }

  .hub-head { margin-bottom: 48px; }
  .eyebrow { font-family: 'Space Mono', monospace; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold, #B17C2E); margin-bottom: 1rem; }
  h1 { font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: clamp(2rem, 5vw, 2.75rem); line-height: 1.15; letter-spacing: -0.02em; color: var(--ink, #16171D); margin-bottom: 1rem; }
  .lede { font-size: 1.1rem; color: var(--slate, #6B6C73); line-height: 1.6; max-width: 60ch; }
  .lede a { color: var(--ink, #16171D); text-decoration: underline; text-decoration-color: var(--gold, #B17C2E); text-underline-offset: 3px; }

  .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-bottom: 32px; }
  .card { background: white; border: 1px solid var(--mesh, #C9CAC4); border-radius: 4px; padding: 28px 26px; text-decoration: none; color: var(--ink, #16171D); transition: border-color 0.15s, transform 0.15s; position: relative; display: block; }
  .card::before { content: ''; position: absolute; top: -1px; left: 28px; right: 28px; height: 2px; background: var(--gold, #B17C2E); opacity: 0; transition: opacity 0.15s; }
  .card:hover:not(.card-coming) { border-color: var(--gold, #B17C2E); transform: translateY(-2px); }
  .card:hover:not(.card-coming)::before { opacity: 1; }

  .card-coming { opacity: 0.6; cursor: default; }
  .card-coming .card-arrow { color: var(--slate, #6B6C73); }

  .card-eyebrow { font-family: 'Space Mono', monospace; font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold, #B17C2E); display: block; margin-bottom: 0.75rem; }
  .card-coming .card-eyebrow { color: var(--slate, #6B6C73); }

  .card h2 { font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: 1.25rem; line-height: 1.3; margin-bottom: 0.75rem; color: var(--ink, #16171D); }
  .card p { font-family: 'Space Grotesk', sans-serif; font-size: 0.95rem; color: var(--slate, #6B6C73); line-height: 1.5; margin-bottom: 1.25rem; }
  .card-arrow { font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem; font-weight: 600; color: var(--gold, #B17C2E); }

  .hint { background: rgba(177, 124, 46, 0.06); border-left: 2px solid var(--gold, #B17C2E); padding: 16px 20px; margin-bottom: 32px; }
  .hint p { font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem; color: var(--ink, #16171D); margin: 0; line-height: 1.5; }

  .newsletter-slot { margin-top: 24px; }

  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
