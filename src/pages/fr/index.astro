---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MethodologyBox from "../../components/MethodologyBox.astro";
import EmailCaptureInline from "../../components/EmailCaptureInline.astro";
import AuthorBio from "../../components/AuthorBio.astro";
import { organization, webPage, buildGraph } from "../../lib/schema";

const site = "https://siftedtools.com";
const url = `${site}/fr/`;
const updated = "2026-06-22";

// JSON-LD : organisation + page d'accueil
const schema = [
  buildGraph(
    organization(),
    webPage({
      url,
      title: "Outils IA pour l'e-commerce : le verdict, pas la liste",
      description:
        "Comparateur indépendant des meilleurs outils IA pour boutiques Shopify, WooCommerce et DTC. Testés sur de vraies boutiques, classés au mérite.",
      updatedAt: new Date(updated),
      lang: "fr",
    })
  ),
];

// 3 verdicts mis en avant -> chacun cliquable vers son comparatif (toutes pages existent)
const picks = [
  { cat: "Service client", tool: "Gorgias", line: "Pour les boutiques qui scalent leur SAV sans grossir l'équipe.", href: "/fr/outils-ia-service-client/" },
  { cat: "Fiches produits", tool: "Jasper", line: "Rédaction en masse et multilingue, pensée pour les gros catalogues.", href: "/fr/outils-ia-fiches-produits/" },
  { cat: "Avis Shopify", tool: "Loox", line: "L'app d'avis visuels la plus aboutie pour les marques DTC et lifestyle.", href: "/fr/loox-vs-judge-me/" },
];

// Categories : `live` indique si la page existe deja
const categories = [
  { t: "Service client", d: "Chatbots et helpdesk IA", href: "/fr/outils-ia-service-client/", live: true },
  { t: "Fiches produits", d: "Rédaction à grande échelle", href: "/fr/outils-ia-fiches-produits/", live: true },
  { t: "Avis Shopify", d: "Loox vs Judge.me vs Yotpo", href: "/fr/loox-vs-judge-me/", live: true },
  { t: "Email marketing", d: "Séquences et segmentation", href: "/fr/comparatifs/", live: false },
  { t: "SEO & contenu", d: "Articles et pages optimisées", href: "/fr/comparatifs/", live: false },
  { t: "Créas publicitaires", d: "Visuels et accroches d'ads", href: "/fr/comparatifs/", live: false },
];
---
<BaseLayout
  title="Outils IA pour l'e-commerce : le verdict, pas la liste | SiftedTools"
  description="Comparateur indépendant des meilleurs outils IA pour boutiques Shopify, WooCommerce et DTC. Testés sur de vraies boutiques, classés au mérite."
  canonical={url}
  alternates={[{ lang: "fr", href: url }]}
  updatedAt={updated}
  schema={schema}
>
  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <span class="eyebrow">Outils IA pour l'e-commerce · Édition France</span>
      <h1>Le verdict,<br />pas la liste.</h1>
      <p class="lede">
        Des centaines d'outils IA promettent de booster ta boutique. On les teste sur de
        vraies boutiques, on en garde une poignée, et on te dit lequel choisir selon ton besoin.
      </p>
      <div class="hero-cta">
        <a class="btn btn-quiz" href="/fr/barometre-geo/">Voir le Baromètre GEO</a>
        <a class="btn btn-ghost" href="/fr/comparatifs/">Parcourir les comparatifs</a>
      </div>
    </div>

    <!-- LE CRIBLE : 3 verdicts cliquables -->
    <div class="wrap">
      <div class="sieve-label">▼ Ce qui ressort du crible ▼</div>
      <div class="picks">
        {picks.map((p, i) => (
          <a class="pick" href={p.href}>
            <span class="mono pick-rank">{String(i + 1).padStart(2, "0")}</span>
            <div class="pick-body">
              <div class="pick-head">
                <strong class="ui">{p.tool}</strong>
                <span class="tag">Meilleur · {p.cat}</span>
              </div>
              <p>{p.line}</p>
            </div>
            <span class="pick-arrow ui" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="sieve" role="presentation"></div>

  <!-- CATEGORIES -->
  <section class="cats">
    <div class="wrap">
      <div class="cats-head">
        <span class="eyebrow">Par besoin</span>
        <h2 class="ui">Qu'est-ce que tu veux améliorer ?</h2>
      </div>
      <div class="cat-grid">
        {categories.map((c) => (
          <a class={`cat ${c.live ? '' : 'cat-soon'}`} href={c.href}>
            <h3 class="ui">{c.t}</h3>
            <p>{c.d}</p>
            <span class="cat-link ui">{c.live ? 'Voir le comparatif →' : 'En préparation · Bientôt'}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- METHODOLOGIE -->
  <section class="method-section">
    <div class="wrap"><MethodologyBox /></div>
  </section>

  <!-- BAROMETRE GEO : le différenciateur -->
  <section class="baro">
    <div class="wrap baro-inner">
      <div class="baro-copy">
        <span class="eyebrow">Notre signal exclusif</span>
        <h2 class="ui">On mesure qui les IA recommandent vraiment</h2>
        <p>
          Quand on demande à ChatGPT, Claude ou Perplexity « quel outil pour ma boutique »,
          certains noms reviennent, d'autres jamais. Notre baromètre GEO suit ces citations
          dans le temps. C'est une donnée que personne d'autre ne te donne, et elle nourrit
          chacun de nos verdicts.
        </p>
        <a class="btn btn-ghost" href="/fr/barometre-geo/">Voir le baromètre</a>
      </div>
      <div class="baro-viz" aria-hidden="true">
        <div class="baro-row"><span class="ui">Cité par 4 IA / 4</span><span class="bar b4"></span></div>
        <div class="baro-row"><span class="ui">Cité par 3 / 4</span><span class="bar b3"></span></div>
        <div class="baro-row"><span class="ui">Cité par 1 / 4</span><span class="bar b1"></span></div>
        <div class="baro-row dim"><span class="ui">Jamais cité</span><span class="bar b0"></span></div>
      </div>
    </div>
  </section>

  <!-- CAPTURE EMAIL -->
  <section class="email-section">
    <div class="wrap"><EmailCaptureInline /></div>
  </section>

  <!-- AUTEUR (E-E-A-T) -->
  <section class="author-section">
    <div class="wrap"><AuthorBio updatedAt={updated} /></div>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero{padding:72px 0 40px}
  .hero h1{font-size:clamp(44px,7vw,76px);line-height:1.02;margin:18px 0 0}
  .lede{font-size:20px;color:var(--slate);max-width:60ch;margin:22px 0 0;line-height:1.55}
  .hero-cta{display:flex;gap:12px;flex-wrap:wrap;margin:30px 0 56px}

  .sieve-label{margin-bottom:18px}
  .picks{display:flex;flex-direction:column;gap:12px}
  .pick{display:flex;align-items:center;gap:18px;background:var(--card);border:1px solid var(--mesh);border-radius:var(--radius-lg);padding:20px 22px;transition:border-color .15s,transform .15s}
  .pick:hover{border-color:var(--gold-light);transform:translateX(3px)}
  .pick-rank{color:var(--gold);font-size:15px}
  .pick-body{flex:1}
  .pick-head{display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:5px}
  .pick-head strong{font-size:19px}
  .pick-body p{font-size:15px;color:var(--slate)}
  .pick-arrow{color:var(--gold);font-size:20px}

  /* CATEGORIES */
  .cats-head{margin-bottom:26px}
  .cats-head h2{font-size:30px;margin-top:6px}
  .cat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
  .cat{background:var(--card);border:1px solid var(--mesh);border-radius:var(--radius-lg);padding:24px 22px;transition:border-color .15s,transform .15s}
  .cat:hover{border-color:var(--gold-light);transform:translateY(-2px)}
  .cat h3{font-size:19px;margin-bottom:6px}
  .cat p{font-size:14.5px;color:var(--slate);margin-bottom:16px}
  .cat-link{font-size:14px;color:var(--gold);font-weight:600}
  .cat-soon{opacity:.7}
  .cat-soon .cat-link{color:var(--slate)}

  /* BAROMETRE */
  .baro{background:var(--ink)}
  .baro-inner{display:grid;grid-template-columns:1.1fr .9fr;gap:48px;align-items:center}
  .baro-copy .eyebrow{color:var(--gold-light)}
  .baro-copy h2{color:var(--porcelain);font-size:30px;margin:8px 0 14px}
  .baro-copy p{color:#C7C8CD;font-size:16px;line-height:1.6;max-width:48ch;margin-bottom:24px}
  .baro-copy .btn-ghost{color:var(--porcelain);border-color:#3A3B43}
  .baro-copy .btn-ghost:hover{background:var(--porcelain);color:var(--ink)}
  .baro-viz{display:flex;flex-direction:column;gap:14px}
  .baro-row{display:flex;align-items:center;gap:14px;font-size:13px;color:#C7C8CD}
  .baro-row .ui{flex:0 0 130px}
  .bar{height:14px;border-radius:7px;background:var(--gold)}
  .bar.b4{width:100%}
  .bar.b3{width:74%}
  .bar.b1{width:32%}
  .bar.b0{width:8%;background:#3A3B43}
  .baro-row.dim{color:var(--muted)}

  @media (max-width:820px){
    .cat-grid{grid-template-columns:1fr 1fr}
    .baro-inner{grid-template-columns:1fr;gap:32px}
  }
  @media (max-width:480px){
    .cat-grid{grid-template-columns:1fr}
    .pick-arrow{display:none}
  }
  @media (prefers-reduced-motion:reduce){
    .pick:hover,.cat:hover{transform:none}
  }
</style>
