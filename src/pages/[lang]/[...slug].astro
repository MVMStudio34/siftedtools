---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import AffiliateDisclosure from "../../components/AffiliateDisclosure.astro";
import AuthorBio from "../../components/AuthorBio.astro";
import FAQ from "../../components/FAQ.astro";
import EmailCaptureInline from "../../components/EmailCaptureInline.astro";
import RelatedComparisons from "../../components/RelatedComparisons.astro";
import OfferButtons from "../../components/OfferButtons.astro";
import { organization, webPage, breadcrumb, faqPage, softwareApplication, buildGraph } from "../../lib/schema";
import { useTranslations } from "../../i18n/utils";

const SITE = "https://siftedtools.com";

export const getStaticPaths: GetStaticPaths = async () => {
  const COLLECTIONS = ["tools", "guides", "glossary", "benchmarks"] as const;
  const slugOf = (id, lang) => {
    const clean = id.replace(/\.(md|mdx)$/i, "");
    return clean.startsWith(`${lang}/`) ? clean.slice(lang.length + 1) : clean;
  };
  const paths = [];
  for (const col of COLLECTIONS) {
    const entries = await getCollection(col, ({ data }) => data.draft !== true);
    for (const entry of entries) {
      const lang = entry.data.lang;
      const slug = slugOf(entry.id, lang);
      paths.push({ params: { lang, slug }, props: { entry, lang, slug, collection: col } });
    }
  }
  return paths;
};

const { entry, lang, slug, collection } = Astro.props;
const t = useTranslations(lang);
const data = entry.data;
const pageUrl = `${SITE}/${lang}/${slug}/`;
const dateStr = new Date(data.updatedAt).toISOString().slice(0, 10);
const { Content } = await render(entry);

const nodes = [
  organization(),
  webPage({ url: pageUrl, title: data.title, description: data.description, updatedAt: new Date(data.updatedAt), lang }),
  breadcrumb([
    { name: t("breadcrumb.home"), url: `${SITE}/${lang}/` },
    { name: data.title, url: pageUrl },
  ]),
];
if (data.faq?.length) nodes.push(faqPage(data.faq.map((f) => ({ question: f.q, answer: f.a }))));
// B7 : un SoftwareApplication par outil comparé (collection tools uniquement)
if (collection === "tools" && data.apps?.length) {
  for (const app of data.apps) nodes.push(softwareApplication(app));
}
const schema = [buildGraph(...nodes)];

const showRelated = collection === "tools";
---
<BaseLayout
  title={`${data.title} | SiftedTools`}
  description={data.description}
  canonical={pageUrl}
  alternates={data.alternates}
  updatedAt={dateStr}
  schema={schema}
>
  <article class="article">
    <nav class="crumbs ui" aria-label={t("breadcrumb.aria")}>
      <a href={`/${lang}/`}>{t("breadcrumb.home")}</a>
      <span aria-hidden="true">/</span>
      <span>{data.title}</span>
    </nav>

    <header class="art-head">
      <h1 class="ui">{data.title}</h1>
      <p class="meta note">{t("page.reviewedBy")} {data.reviewedBy} · {t("page.updated")} {dateStr}</p>
    </header>

    <div class="disclosure-slot"><AffiliateDisclosure compact={true} /></div>

    {data.offers?.length > 0 && (
      <OfferButtons offers={data.offers} eyebrow={t("cta.testNow")} />
    )}

    <div class="prose">
      <Content />
    </div>

    <div class="email-slot"><EmailCaptureInline /></div>

    {data.faq?.length > 0 && (
      <div class="faq-slot"><FAQ items={data.faq} /></div>
    )}

    {collection === "tools" && data.offers?.length > 0 && (
      <div class="cta-repeat">
        <h2 class="ui">{t("cta.readyTitle")}</h2>
        <OfferButtons offers={data.offers} eyebrow={t("cta.readyEyebrow")} />
      </div>
    )}

    {showRelated && (
      <div class="related-slot"><RelatedComparisons currentSlug={slug} lang={lang} limit={3} /></div>
    )}

    <div class="author-slot"><AuthorBio updatedAt={dateStr} /></div>
  </article>
</BaseLayout>

<style>
  .article{max-width:760px;margin:0 auto;padding:40px 24px 0}
  .crumbs{display:flex;gap:10px;font-size:13px;color:var(--slate);margin-bottom:26px;flex-wrap:wrap}
  .crumbs a{color:var(--gold)}
  .crumbs span[aria-hidden]{color:var(--muted)}
  .art-head h1{font-size:clamp(30px,5vw,44px);line-height:1.08}
  .art-head .meta{margin-top:14px}
  .disclosure-slot{margin:26px 0}
  .cta-repeat{margin-top:48px}
  .cta-repeat h2{font-size:clamp(22px,3vw,28px);margin-bottom:4px}
  .email-slot{margin:48px 0}
  .faq-slot{margin-top:48px}
  .related-slot{margin-top:8px}
  .author-slot{margin:48px 0}
</style>
