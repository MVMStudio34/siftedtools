---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
const { updatedAt } = Astro.props as { updatedAt?: string };
const t = useTranslations(getLangFromUrl(Astro.url));
// Initiales en avatar le temps d'avoir une vraie photo.
const initials = t("author.name").split(" ").map((w) => w[0]).join("").slice(0, 2);
---
<div class="author">
  <div class="avatar ui" aria-hidden="true">{initials}</div>
  <div class="meta">
    <p class="who"><span class="label note">{t("page.reviewedBy")}</span> <strong class="ui">{t("author.name")}</strong></p>
    <p class="bio">{t("author.bio")}</p>
    {updatedAt && <p class="note upd">{t("page.updated")} {updatedAt}</p>}
  </div>
</div>

<style>
  .author{display:flex;gap:16px;align-items:flex-start;background:var(--card);border:1px solid var(--mesh);border-radius:var(--radius-lg);padding:20px 22px}
  .avatar{flex:0 0 48px;width:48px;height:48px;border-radius:50%;background:var(--ink);color:var(--porcelain);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px}
  .who{font-size:15px;margin-bottom:6px}
  .who .label{display:block;margin-bottom:2px}
  .who strong{font-size:17px}
  .bio{font-size:15px;color:var(--slate);line-height:1.55;max-width:60ch}
  .upd{margin-top:8px}
</style>
