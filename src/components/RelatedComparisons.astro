---
import { getCollection } from "astro:content";

interface Props {
  currentSlug: string;
  lang: string;
  limit?: number;
}

const { currentSlug, lang, limit = 3 } = Astro.props;

// Récupère tous les comparatifs publiés dans la même langue, exclut l'article courant
const all = await getCollection("tools", ({ data }) => data.draft !== true && data.lang === lang);

const others = all
  .filter((entry) => {
    const slug = entry.id.replace(/\.(md|mdx)$/i, "").replace(new RegExp(`^${lang}/`), "");
    return slug !== currentSlug;
  })
  // Tri par geoPriorityScore desc (les pages les plus stratégiques en premier)
  .sort((a, b) => (b.data.geoPriorityScore || 0) - (a.data.geoPriorityScore || 0))
  .slice(0, limit);

const slugOf = (entry: typeof others[0]) => entry.id.replace(/\.(md|mdx)$/i, "").replace(new RegExp(`^${lang}/`), "");
---

{others.length > 0 && (
  <section class="related" aria-label="Comparatifs liés">
    <div class="related-head">
      <p class="related-eyebrow">Continuer la lecture</p>
      <h2 class="related-title">Autres comparatifs SiftedTools</h2>
    </div>

    <div class="related-grid">
      {others.map((entry) => (
        <a class="related-card" href={`/${lang}/${slugOf(entry)}/`}>
          <span class="related-card-eyebrow">Comparatif</span>
          <h3>{entry.data.title}</h3>
          <p>{entry.data.description}</p>
          <span class="related-arrow">Lire le verdict →</span>
        </a>
      ))}
    </div>

    <div class="related-footer">
      <a href={`/${lang}/comparatifs/`} class="related-all">Voir tous les comparatifs →</a>
    </div>
  </section>
)}

<style>
  .related {
    margin: 56px 0 40px;
    padding: 32px 0 0;
    border-top: 1px solid var(--mesh, #C9CAC4);
  }

  .related-head { margin-bottom: 24px; }

  .related-eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold, #B17C2E);
    margin-bottom: 0.5rem;
  }

  .related-title {
    font-family: 'Newsreader', Georgia, serif;
    font-weight: 500;
    font-size: 1.5rem;
    line-height: 1.2;
    color: var(--ink, #16171D);
    letter-spacing: -0.01em;
    margin: 0;
  }

  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .related-card {
    display: block;
    background: white;
    border: 1px solid var(--mesh, #C9CAC4);
    border-radius: 4px;
    padding: 20px 24px;
    text-decoration: none;
    color: var(--ink, #16171D);
    transition: border-color 0.15s ease, transform 0.15s ease;
    position: relative;
  }

  .related-card::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 24px;
    right: 24px;
    height: 2px;
    background: var(--gold, #B17C2E);
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .related-card:hover {
    border-color: var(--gold, #B17C2E);
    transform: translateY(-1px);
  }

  .related-card:hover::before { opacity: 1; }

  .related-card-eyebrow {
    display: block;
    font-family: 'Space Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold, #B17C2E);
    margin-bottom: 0.5rem;
  }

  .related-card h3 {
    font-family: 'Newsreader', Georgia, serif;
    font-weight: 500;
    font-size: 1.1rem;
    line-height: 1.3;
    color: var(--ink, #16171D);
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.005em;
  }

  .related-card p {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--slate, #6B6C73);
    margin: 0 0 0.75rem 0;
  }

  .related-arrow {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--gold, #B17C2E);
  }

  .related-footer {
    margin-top: 16px;
    text-align: right;
  }

  .related-all {
    font-family: 'Space Mono', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    color: var(--ink, #16171D);
    text-decoration: underline;
    text-decoration-color: var(--gold, #B17C2E);
    text-underline-offset: 4px;
    transition: color 0.15s ease;
  }

  .related-all:hover { color: var(--gold, #B17C2E); }
</style>
