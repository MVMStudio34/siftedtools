---
const steps = [
  { n: "01", t: "On recense", d: "Tous les outils crédibles d'une catégorie, pas une sélection de complaisance." },
  { n: "02", t: "On teste", d: "Sur de vraies boutiques : prise en main, qualité réelle, pièges, prix réel." },
  { n: "03", t: "On mesure", d: "Notre baromètre GEO suit qui les IA citent vraiment. Donnée propriétaire." },
  { n: "04", t: "On tranche", d: "Un verdict clair par besoin. Le bon outil, pas la liste de tous les outils." },
];
---
<div class="method">
  <div class="method-head">
    <span class="eyebrow">Méthodologie</span>
    <h2 class="ui">Comment on passe les outils au crible</h2>
  </div>
  <ol class="steps">
    {steps.map((s) => (
      <li>
        <span class="mono num">{s.n}</span>
        <h3 class="ui">{s.t}</h3>
        <p>{s.d}</p>
      </li>
    ))}
  </ol>
</div>

<style>
  .method-head{margin-bottom:26px}
  .method-head h2{font-size:30px;margin-top:6px}
  .steps{list-style:none;display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--mesh);border:1px solid var(--mesh);border-radius:var(--radius-lg);overflow:hidden}
  .steps li{background:var(--card);padding:24px 20px}
  .num{color:var(--gold);font-size:13px;letter-spacing:.1em}
  .steps h3{font-size:18px;margin:10px 0 8px}
  .steps p{font-size:14.5px;color:var(--slate);line-height:1.5}
  @media (max-width:820px){.steps{grid-template-columns:repeat(2,1fr)}}
  @media (max-width:480px){.steps{grid-template-columns:1fr}}
</style>
