---
import AffiliateDisclosure from "./AffiliateDisclosure.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = `/${lang}`;
const year = new Date().getFullYear();
const links = [
  { href: `${base}/methodologie/`, label: t("footer.method") },
  { href: `${base}/barometre-geo/`, label: t("footer.barometer") },
  { href: `${base}/a-propos/`, label: t("footer.about") },
  { href: `${base}/mentions-legales/`, label: t("footer.legal") },
  { href: `${base}/confidentialite/`, label: t("footer.privacy") },
];
---
<footer class="site-footer">
  <div class="wrap">
    <div class="disclosure-slot"><AffiliateDisclosure /></div>
    <div class="foot-grid">
      <div class="foot-brand">
        <span class="ui name">{t("brand.name")}</span>
        <p class="note">{t("footer.rights")}</p>
      </div>
      <nav class="foot-links ui" aria-label="Liens de pied de page">
        {links.map((l) => <a href={l.href}>{l.label}</a>)}
      </nav>
    </div>
    <p class="copy note">© {year} {t("brand.name")}</p>
  </div>
</footer>

<style>
  .site-footer{border-top:1px solid var(--mesh);background:var(--card);padding:48px 0 36px;margin-top:40px}
  .disclosure-slot{margin-bottom:36px}
  .foot-grid{display:flex;justify-content:space-between;gap:32px;flex-wrap:wrap;align-items:flex-start}
  .foot-brand .name{font-size:18px;font-weight:700}
  .foot-brand .note{margin-top:8px;max-width:34ch}
  .foot-links{display:flex;flex-wrap:wrap;gap:18px;font-size:14px}
  .foot-links a{color:var(--slate)}
  .foot-links a:hover{color:var(--ink)}
  .copy{margin-top:30px}
</style>
