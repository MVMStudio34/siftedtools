---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getLangFromUrl } from "../i18n/utils";

interface Alternate { lang: string; href: string; }
interface Props {
  title: string;
  description: string;
  canonical?: string;
  alternates?: Alternate[];
  updatedAt?: string;          // ISO, ex "2026-06-21"
  ogImage?: string;
  robots?: string;
  schema?: object[];           // blocs JSON-LD à injecter
}

const {
  title, description, canonical, alternates = [],
  updatedAt, ogImage, robots = "index,follow", schema = [],
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const site = "https://siftedtools.com";
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, site).href;
const ogImg = ogImage ?? `${site}/og-default.png`;
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={robots} />
<meta name="google-site-verification" content="8T8T_gCNFa5r6PRQXnkl-pJW7uUWZNOo2bPNA0Oj2uQ" />
  <link rel="canonical" href={canonicalUrl} />

  {/* hreflang : une ligne par langue publiée + x-default */}
  {alternates.map((a) => (
    <link rel="alternate" hreflang={a.lang} href={a.href} />
  ))}
  {alternates.length > 0 && (
    <link rel="alternate" hreflang="x-default" href={alternates[0].href} />
  )}

  {/* Open Graph */}
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImg} />
  <meta property="og:locale" content={lang} />
  <meta name="twitter:card" content="summary_large_image" />

  {updatedAt && <meta name="article:modified_time" content={updatedAt} />}

  {/* Polices : 3 voix (Space Grotesk / Newsreader / Space Mono) */}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Space+Grotesk:wght@500;600;700&family=Space+Mono:wght@400;700&display=swap"
    rel="stylesheet"
  />

  {/* JSON-LD : injecté tel quel depuis les pages (cf. src/lib/schema.ts) */}
  {schema.map((block) => (
    <script type="application/ld+json" set:html={JSON.stringify(block)} />
  ))}

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
